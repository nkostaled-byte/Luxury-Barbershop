{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "luxury-barbershop",
  "compatibility_date": "2026-07-20",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "VITE_API_BASE_URL":"https://mygrafix-dashboard-worker.mygrafix.workers.dev",
    "VITE_CLIENT_ID": "cli-sovereign"
  }
}