# Public Vite configuration. Copy this file to .env.local and replace every
# placeholder. VITE_* values are bundled into the browser: never put Supabase
# service-role, Resend, R2, or Cloudflare credentials here.

# Deployed Cloudflare Worker. It handles all submissions and emails via Resend.
VITE_API_BASE_URL="https://YOUR-WORKER.workers.dev"

# The public client identifier stored in the Worker/Supabase clients table.
VITE_CLIENT_ID="YOUR-CLIENT-ID"

# Public read-only catalogue and branding data.
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR-SUPABASE-ANON-KEY"
