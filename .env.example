# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: The URL of the backend Cloudflare Worker service.
VITE_API_BASE_URL="https://mygrafix-dashboard-worker.mygrafix.workers.dev"

# VITE_WORKER_URL: The URL of the backend Cloudflare Worker service.
VITE_WORKER_URL="https://mygrafix-dashboard-worker.mygrafix.workers.dev"

# VITE_CLIENT_ID: The identifier of the specific luxury barber business client.
VITE_CLIENT_ID="cli-sovereign"

# VITE_SUPABASE_URL: Your Supabase project URL (Settings > API > Project URL).
VITE_SUPABASE_URL="https://eapkysbpbreovmqlpzvi.supabase.co"

# VITE_SUPABASE_ANON_KEY: Your Supabase anon/public key (Settings > API > anon public).
# Safe to expose in the browser — Row Level Security policies restrict what it can read.
# Never put the service_role key here.
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVhcGt5c2JwYnJlb3ZtcWxwenZpIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4NDE1MDIzMiwiZXhwIjoyMDk5NzI2MjMyfQ.bWqyL42c3_8jeFNxq2qkbIR3vA3z3Kgv6znLEbagaJA"
